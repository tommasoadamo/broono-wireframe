  "answerKeys": {
    "q1": "dog_name",
    "q2": "dog_breed",
    "q3": "dog_weight",
    "q4": "dog_age_years",
    "q5": "dog_aspiration",
    "q6": "dog_energy",
    "q7": "dog_digestion",
    "q8": "dog_skin",
    "q9": "dog_stress",
    "q10": "dog_joints"
